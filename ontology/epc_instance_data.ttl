@prefix epc: <http://tecnicasreunidas.es/ontology/epc#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://tecnicasreunidas.es/ontology/epc> a owl:Ontology ;
    rdfs:label "EPC Compliance TKG Ontology"@en ;
    rdfs:comment """OWL-2 DL ontology for bitemporal EPC project compliance monitoring.
Models the Tecnicas Reunidas Meram Refinery Expansion project.
Temporal layer uses valid-time (valid_from / valid_to) and
transaction-time (tx_time) following ISO 19108 bitemporal semantics."""@en ;
    owl:versionInfo "1.0" .

epc:CPI a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "Cost Performance Index (CPI)"@en ;
    rdfs:comment "CPI = EV / AC. Requires actual cost data (not available in this dataset; reserved for future integration with TR cost management system)."@en ;
    rdfs:domain epc:Activity ;
    rdfs:range xsd:decimal .

epc:ComplianceViolation a owl:Class ;
    rdfs:label "Compliance Violation"@en ;
    rdfs:comment """A WorkerAssignment where the assigned worker does not hold
all certifications required by the step's work permit during the assignment window.
Instances are materialized by SPARQL CONSTRUCT query Q5."""@en ;
    rdfs:subClassOf epc:WorkerAssignment .

epc:SPI a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "Schedule Performance Index (SPI)"@en ;
    rdfs:comment "SPI = EV / PV. SPI < 1.0 indicates schedule slippage; < 0.9 signals critical delay risk."@en ;
    rdfs:domain epc:Activity ;
    rdfs:range xsd:decimal .

epc:area a owl:DatatypeProperty ;
    rdfs:label "plant area"@en ;
    rdfs:domain epc:Activity ;
    rdfs:range xsd:string .

epc:belongsTo a owl:ObjectProperty ;
    rdfs:label "belongs to family"@en ;
    rdfs:domain epc:Activity ;
    rdfs:range epc:Family .

epc:cwp a owl:DatatypeProperty ;
    rdfs:label "Construction Work Package (CWP)"@en ;
    rdfs:domain epc:Activity ;
    rdfs:range xsd:string .

epc:discipline a owl:DatatypeProperty ;
    rdfs:label "discipline"@en ;
    rdfs:domain epc:Worker ;
    rdfs:range xsd:string .

epc:earnedValue a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "Earned Value (EV)"@en ;
    rdfs:comment "Hours earned based on reported progress. Source: earned_hours."@en ;
    rdfs:domain epc:Activity ;
    rdfs:range xsd:decimal .

epc:hasStep a owl:ObjectProperty ;
    rdfs:label "has step"@en ;
    rdfs:domain epc:Activity ;
    rdfs:range epc:Step .

epc:id a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "identifier"@en ;
    rdfs:range xsd:string .

epc:includes a owl:ObjectProperty ;
    rdfs:label "includes"@en ;
    rdfs:domain epc:Project ;
    rdfs:range epc:Activity .

epc:name a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
    rdfs:range xsd:string .

epc:order a owl:DatatypeProperty ;
    rdfs:label "execution order within activity"@en ;
    rdfs:domain epc:Step ;
    rdfs:range xsd:integer .

epc:permitType a owl:DatatypeProperty ;
    rdfs:label "permit type required"@en ;
    rdfs:domain epc:Step ;
    rdfs:range xsd:string .

epc:plannedValue a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "Planned Value (PV)"@en ;
    rdfs:comment "Budgeted hours for this activity (proxy for BAC). Source: estimated_hours."@en ;
    rdfs:domain epc:Activity ;
    rdfs:range xsd:decimal .

epc:precedes a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "precedes"@en ;
    rdfs:comment "Irreflexive in practice (no self-loops in EPC schedules)."@en,
        "Transitively closed step dependency: s1 precedes s2 means s1 must complete before s2 starts."@en ;
    rdfs:domain epc:Step ;
    rdfs:range epc:Step .

epc:progressPct a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "Progress percentage"@en ;
    rdfs:comment "Percentage completion of the activity (0–100). Source: progress_pct."@en ;
    rdfs:domain epc:Activity ;
    rdfs:range xsd:decimal .

epc:requiresPermit a owl:ObjectProperty ;
    rdfs:label "requires permit"@en ;
    rdfs:domain epc:Step ;
    rdfs:range epc:WorkPermit .

epc:txTime a owl:DatatypeProperty ;
    rdfs:label "transaction time (system recording time)"@en ;
    rdfs:comment "When this fact was inserted into the system. Supports 'as-of' bitemporal queries."@en ;
    rdfs:range xsd:dateTime .

epc:validFrom a owl:DatatypeProperty ;
    rdfs:label "valid from (valid time start)"@en ;
    rdfs:comment "The real-world moment from which this fact holds."@en ;
    rdfs:range xsd:dateTime ;
    rdfs:subPropertyOf time:hasBeginning .

epc:validTo a owl:DatatypeProperty ;
    rdfs:label "valid to (valid time end)"@en ;
    rdfs:comment "The real-world moment at which this fact ceases to hold. NULL = currently valid."@en ;
    rdfs:range xsd:dateTime .

epc:weightPct a owl:DatatypeProperty ;
    rdfs:label "weight percentage within activity"@en ;
    rdfs:domain epc:Step ;
    rdfs:range xsd:decimal .

